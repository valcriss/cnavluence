{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json --noCheck",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prisma:sync-env": "node -e \"const fs=require('fs');const p='../.env';if(fs.existsSync(p)){fs.copyFileSync(p,'.env');console.log('Synced ../.env -> backend/.env')}else{console.log('No ../.env found')}\"",
    "prisma:generate": "npm run prisma:sync-env && prisma generate",
    "prisma:migrate": "npm run prisma:sync-env && prisma migrate dev",
    "prisma:migrate:deploy": "npm run prisma:sync-env && prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "grant:site-admin": "tsx src/scripts/grant-site-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express-async-errors": "^3.1.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "nanoid": "^5.1.5",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "socket.io": "^4.8.1",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.23",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.11",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "volta": {
    "node": "24.14.0"
  }
}
